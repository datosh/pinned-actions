{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":separateMajorReleases",
    ":preserveSemverRanges"
  ],
  "commitMessagePrefix": "fix(deps): ",
  "addLabels": ["dependencies"],

  "ignorePaths": ["testdata/**"],

  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^frontend/index\\.html$/"],
      "matchStrings": ["cdn\\.jsdelivr\\.net/npm/(?<depName>@?[^@/]+(?:/[^@/]+)?)@(?<currentValue>[^/\"'\\s]+)"],
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^frontend/index\\.html$/"],
      "matchStrings": ["cdnjs\\.cloudflare\\.com/ajax/libs/(?<depName>[^/]+)/(?<currentValue>[^/]+)/"],
      "datasourceTemplate": "cdnjs"
    }
  ],

  "packageRules": [
    {
      "groupName": "Go",
      "matchDatasources": ["go"]
    },
    {
      "groupName": "GitHub Actions",
      "matchDatasources": ["github-actions"]
    }
  ]
}
